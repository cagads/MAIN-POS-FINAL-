<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAIN_POS.MVVM.Views.FeatureView"
             Title="FeatureView">
    
    <FlyoutPage.Flyout>
        <ContentPage Title="Menu" >
            <VerticalStackLayout Padding="20" Spacing="20">
                <Button x:Name="Home" Text="Home" Clicked="Home_Clicked"/>
                <Button x:Name="Users" Text="Users" Clicked="Users_Clicked"/>
                <Button x:Name="Notifications" Text="Notifications" Clicked="Notifications_Clicked"/>
                <Button x:Name="Settings" Text="Settings" Clicked="Settings_Clicked"/>
            </VerticalStackLayout>
        </ContentPage>
    </FlyoutPage.Flyout>

    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>
                <ContentPage Title="Home">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="Welcome to Home Page" />
                    </VerticalStackLayout>
                </ContentPage>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>
    


</FlyoutPage>